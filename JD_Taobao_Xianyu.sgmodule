#!name=京东 & 淘宝 & 闲鱼 自动签到
#!desc=京东签到 · 京东金融养大鹅(签到+喂食) · 京东养猪猪(签到+喂食) · 淘宝淘金币(签到+领金币) · 闲鱼(签到+得骰子)
#!system=ios,mac
#!openUrl=https://github.com/brazhao110/surge-scripts

[Script]
# ============ Cookie 获取 ============
jd_cookie = type=http-request,pattern=^https?:\/\/api\.m\.jd\.com\/client\.action\?functionId=signBeanIndex,requires-body=true,script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/JD_Cookie.js,script-update-interval=0

jdjr_cookie = type=http-request,pattern=^https?:\/\/ms\.jr\.jd\.com\/gw\/generic\/h5\/m\/,requires-body=true,script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/JDJR_Cookie.js,script-update-interval=0

tb_cookie = type=http-request,pattern=^https?:\/\/h5api\.m\.taobao\.com\/h5\/.*mtop\.taobao\.idle\.fish\.common\.,requires-body=true,script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/TB_Cookie.js,script-update-interval=0

xy_cookie = type=http-request,pattern=^https?:\/\/h5api\.m\.taobao\.com\/h5\/.*mtop\.user\.getusersimpleinfo,requires-body=true,script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/XY_Cookie.js,script-update-interval=0

# ============ 定时签到 ============
jd_sign = type=cron,cronexp="5 7 * * *",script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/JD_Sign.js,timeout=30

jd_goose = type=cron,cronexp="0 8 * * *",script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/JD_Goose.js,timeout=30

jd_pig = type=cron,cronexp="15 8 * * *",script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/JD_Pig.js,timeout=30

tb_coin = type=cron,cronexp="30 7 * * *",script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/TB_Coin.js,timeout=30

xy_checkin = type=cron,cronexp="30 8 * * *",script-path=https://raw.githubusercontent.com/brazhao110/surge-scripts/main/XY_Checkin.js,timeout=30

[MITM]
hostname = %APPEND% api.m.jd.com, ms.jr.jd.com, h5api.m.taobao.com
